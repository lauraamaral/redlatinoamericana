---
import BaseLayout from '../layouts/BaseLayout.astro';
const pageTitle = "Formulario para nuevos miembros";
---

<BaseLayout pageTitle={pageTitle}>
  <section class="form-section">
    <h2>Formulario / Formulário / Form</h2>

    <form id="new-member-form" enctype="multipart/form-data">
      <!-- ✅ Mandatory fields -->
      <div class="form-group">
        <label for="full_name">Nombre completo / Nome completo / Full name *</label>
        <input type="text" id="full_name" name="full_name" required />
      </div>

      <div class="form-group">
        <label for="phone_number">Teléfono / Telefone / Phone number *</label>
        <input type="tel" id="phone_number" name="phone_number" required />
      </div>

      <div class="form-group">
        <label for="home_country">País de origen / País de origem / Home country *</label>
        <input type="text" id="home_country" name="home_country" required />
      </div>

      <div class="form-group">
        <label for="city">Ciudad / Cidade / City *</label>
        <input type="text" id="city" name="city" required />
      </div>

      <div class="form-group">
        <label for="location">Ubicación / Localização / Location *</label>
        <input type="text" id="location" name="location" required />
      </div>

      <div class="form-group">
        <label for="professional_email">Correo profesional / Email profissional / Professional email *</label>
        <input type="email" id="professional_email" name="professional_email" required />
      </div>

      <div class="form-group">
        <label for="email">Correo / Email / Email *</label>
        <input type="email" id="email" name="email" required />
      </div>

      <div class="form-group">
        <label for="agree_to_publish_profile">¿Publicar perfil? / Publicar perfil? / Publish profile? *</label>
        <select id="agree_to_publish_profile" name="agree_to_publish_profile" required>
          <option value="true">Sí / Sim / Yes</option>
          <option value="false">No / Não / No</option>
        </select>
      </div>

      <!-- ✅ Optional fields -->
      <div class="form-group">
        <label for="education">Educación / Educação / Education</label>
        <input type="text" id="education" name="education" />
      </div>

      <div class="form-group">
        <label for="affiliation">Afiliación / Afiliação / Affiliation</label>
        <input type="text" id="affiliation" name="affiliation" />
      </div>

      <!-- ✅ CHECKBOX-BASED RESEARCH INTERESTS -->
      <div class="form-group">
        <label>
          Intereses de investigación / Interesses de pesquisa / Research interests
        </label>
        <div id="research_interests_container" class="checkbox-container"></div>
      </div>

      <div class="form-group">
        <label for="links_social_media">Redes sociales / Redes sociais / Social media (link, not just username)</label>
        <input
          type="url"
          id="links_social_media"
          name="links_social_media"
          placeholder="https://www.linkedin.com/in/alberteinstein/"
        />
      </div>

      <div class="form-group">
        <label for="main_motivation">Motivación principal / Motivação principal / Main motivation</label>
        <textarea id="main_motivation" name="main_motivation"></textarea>
      </div>

      <!-- ✅ Checkbox para aceptar leer el PDF -->
      <style>
      /* This is the visible window on your page */
      #pdf-container {
        width: 100%;
        height: 500px; 
        border: 2px solid #333;
        overflow-y: auto; /* We use the ACTUAL scroll of this div */
        position: relative;
        background: #525659;
      }

      /* We make the iframe height massive (e.g., 3000px) */
      /* This forces the PDF to unfold completely inside the container */
      #pdf-iframe {
        width: 100%;
        height: 3500px; 
        border: none;
        display: block;
      }

      /* Marker at the very bottom */
      #bottom-sentinel {
        height: 20px;
        width: 100%;
      }

      .disabled-label { color: #999; cursor: not-allowed; opacity: 0.6; }
      .enabled-label { color: green; font-weight: bold; cursor: pointer; opacity: 1; }
    </style>

    <div class="form-group">
      <div id="pdf-container">
        <iframe id="pdf-iframe" src="/Código de Conducta.pdf"></iframe>
        
        <div id="bottom-sentinel"></div>
      </div>

      <div style="margin-top: 15px;">
        <label id="checkbox-label" class="disabled-label">
          <input type="checkbox" id="accept_pdf" name="accept_pdf" disabled />
          He leído y aceptado el código de conducta
        </label>
      </div>
    </div>

    <script>
      document.addEventListener("DOMContentLoaded", function () {
        const container = document.getElementById("pdf-container");
        const checkbox = document.getElementById("accept_pdf");
        const label = document.getElementById("checkbox-label");
        const sentinel = document.getElementById("bottom-sentinel");

        // We use IntersectionObserver to see when the 'bottom-sentinel' 
        // enters the visible area of the 'pdf-container'
        const observer = new IntersectionObserver((entries) => {
          entries.forEach(entry => {
            if (entry.isIntersecting) {
              // SUCCESS: User scrolled to the very bottom
              checkbox.disabled = false;
              label.className = "enabled-label";
              console.log("Checkbox unlocked!");
              observer.unobserve(sentinel); // Stop watching once unlocked
            }
          });
        }, {
          root: container, // Watch scrolling inside the container
          threshold: 1.0   // Require the sentinel to be 100% visible
        });

        observer.observe(sentinel);
      });
    </script>

      <button type="submit">Enviar / Enviar / Submit</button>
      <p style="margin-top: 10px; font-size: 0.9rem; color: #666; text-align: center;">
      Tras enviar el formulario aparecerá un enlace a nuestra comunidad de WhatsApp.
      ¡No te vayas sin unirte!
      </p>
    </form>

    <p id="form-message" class="message"></p>
  </section>

  <style>
    .form-section {
      max-width: 700px;
      margin: 2rem auto;
      padding: 2rem;
      background: #fff;
      border-radius: 12px;
      box-shadow: 0 4px 10px rgba(0,0,0,0.1);
    }

    .form-section h2 {
      text-align: center;
      margin-bottom: 1.5rem;
      font-size: 1.5rem;
      color: #333;
    }

    form {
      display: flex;
      flex-direction: column;
      gap: 1rem;
    }

    .form-group {
      display: flex;
      flex-direction: column;
    }

    label {
      margin-bottom: 0.4rem;
      font-weight: 600;
      color: #444;
    }

    input, textarea, select {
      padding: 0.75rem;
      border: 1px solid #ccc;
      border-radius: 8px;
      font-size: 1rem;
    }

    button {
      background: #0070f3;
      color: white;
      padding: 0.9rem;
      font-size: 1rem;
      border: none;
      border-radius: 8px;
      cursor: pointer;
    }

    .message {
      margin-top: 1rem;
      text-align: center;
      font-weight: 500;
    }

    .message img {
      max-width: 200px;
      margin-top: 1rem;
      border-radius: 8px;
    }

    .checkbox-container {
      display: flex;
      flex-wrap: wrap;
      gap: 0.5rem;
      max-height: 300px;
      overflow-y: auto;
      border: 1px solid #ccc;
      padding: 0.75rem;
      border-radius: 8px;
    }

    .checkbox-container label {
      display: flex;
      align-items: center;
      gap: 0.4rem;
      background: #f5f5f5;
      padding: 0.35rem 0.6rem;
      border-radius: 6px;
      cursor: pointer;
      font-size: 0.9rem;
    }

    .grupo-img {
      width: 60%;
      max-width: 240px;
      height: auto;
      display: block;
      margin: 1rem auto;
    }
  </style>

  <script>
    import { createClient } from "@supabase/supabase-js";

    const supabase = createClient(
      import.meta.env.PUBLIC_SUPABASE_URL,
      import.meta.env.PUBLIC_SUPABASE_ANON_KEY
    );

    const form = document.getElementById("new-member-form");
    const messageEl = document.getElementById("form-message");

    form.addEventListener("submit", async (e) => {
      e.preventDefault();
      messageEl.textContent = "⏳ Enviando...";

      const formData = new FormData(form);

      const interestsArray = formData.getAll("research_interests");
      const researchInterestsString = interestsArray
        .map(v => v.replace(/-/g, " "))
        .map(v => v.charAt(0).toUpperCase() + v.slice(1))
        .join(", ");

      const { error } = await supabase.from("pending_members").insert([{
        full_name: formData.get("full_name"),
        phone_number: formData.get("phone_number"),
        home_country: formData.get("home_country"),
        city: formData.get("city"),
        location: formData.get("location"),
        education: formData.get("education"),
        affiliation: formData.get("affiliation"),
        research_interests: researchInterestsString,
        professional_email: formData.get("professional_email"),
        links_social_media: formData.get("links_social_media"),
        main_motivation: formData.get("main_motivation"),
        email: formData.get("email"),
        agree_to_publish_profile: formData.get("agree_to_publish_profile") === "true",
        timestamp: new Date().toISOString()
      }]);

      if (error) {
        messageEl.textContent = "❌ Error al guardar datos.";
      } else {
        messageEl.innerHTML = `
          ✅ ¡Enviado con éxito!<br/><br/>
          <a href="https://chat.whatsapp.com/EASjSLEiLQ0GWepTBZJuGQ?mode=wwt" target="_blank" rel="noopener noreferrer">
            Únete al grupo de WhatsApp
          </a><br/>
          <img src="/grupo.jpg" class="grupo-img" width="240px" height="auto" />

        `;
        form.reset();
      }
    });

    // Research interests (checkboxes)
    const translations = {
      es: [
        "Geología planetaria","Geofísica","Geoquímica","Astrobiología","Habitabilidad planetaria",
        "Astroquímica","Astronomía","Astrofísica","Meteoritos","Biología espacial",
        "Atmósferas planetarias","Detección de exoplanetas","Caracterización de exoplanetas",
        "Química atmosférica","Meteorología y climatología","Clima espacial","Sensoriamento remoto",
        "Arquitectura espacial","Instrumentación","Rovers / Robótica / Cubesats / Nanosatélites",
        "Derecho aeroespacial","Microgravedad","Medicina aeroespacial","Ingeniería aeroespacial"
      ],
      pt: [
        "Geologia planetária","Geofísica","Geoquímica","Astrobiologia","Habitabilidade planetária",
        "Astroquímica","Astronomia","Astrofísica","Meteoritos","Biologia espacial",
        "Atmosferas planetárias","Detecção de exoplanetas","Caracterização de exoplanetas",
        "Química atmosférica","Meteorologia e climatologia","Clima espacial","Sensoriamento remoto",
        "Arquitetura espacial","Instrumentação","Rovers / Robótica / Cubesats / Nanosatélites",
        "Direito aeroespacial","Microgravidade","Medicina aeroespacial","Engenharia aeroespacial"
      ],
      en: [
        "Planetary Geology","Geophysics","Geochemistry","Astrobiology","Planetary Habitability",
        "Astrochemistry","Astronomy","Astrophysics","Meteorites","Space Biology",
        "Planetary Atmospheres","Exoplanet Detection","Exoplanet Characterization",
        "Atmospheric Chemistry","Meteorology and Climatology","Space Weather","Remote Sensing",
        "Space Architecture","Instrumentation","Rovers / Robotics / Cubesats / Nanosatellites",
        "Space Law","Microgravity","Aerospace Medicine","Aerospace Engineering"
      ]
    };

    const userLang = navigator.language.startsWith("es") ? "es" :
                     navigator.language.startsWith("pt") ? "pt" : "en";

    const container = document.getElementById("research_interests_container");

    translations[userLang].forEach(topic => {
      const label = document.createElement("label");
      const checkbox = document.createElement("input");

      checkbox.type = "checkbox";
      checkbox.name = "research_interests";
      checkbox.value = topic.toLowerCase().replace(/\s+/g, "-");

      label.appendChild(checkbox);
      label.appendChild(document.createTextNode(topic));
      container.appendChild(label);
    });
  </script>
</BaseLayout>
